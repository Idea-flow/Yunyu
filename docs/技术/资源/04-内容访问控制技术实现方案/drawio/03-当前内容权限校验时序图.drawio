        <mxCell id="n7" value="7. 返回 contentHtml / tailHiddenContentHtml / contentAccessState" style="rounded=1;arcSize=14;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D1D5DB;strokeWidth=1.2;fontColor=#111827;fontSize=13;" vertex="1" parent="1">
