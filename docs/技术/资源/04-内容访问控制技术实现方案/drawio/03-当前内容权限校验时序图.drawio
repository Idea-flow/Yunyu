        <mxCell id="subtitle" value="聚焦文章详情页真实链路：详情查询、规则判定、验证码校验、授权缓存复用与再次刷新" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#6B7280;" vertex="1" parent="1">
