# 云屿 MySQL 同步脚本配置示例
# 作用：统一管理本地数据库和远程数据库的连接信息，供同步脚本加载。

# Docker MySQL 客户端镜像
# 建议填写你本机已经存在的 MySQL 镜像名，例如：
# MYSQL_CLIENT_IMAGE=mysql:8
# MYSQL_CLIENT_IMAGE=mysql:8.0
MYSQL_CLIENT_IMAGE=mysql:8

# 本地数据库配置
# 如果本地数据库运行在 Docker 并且端口映射到宿主机，Mac / Windows 通常使用 host.docker.internal
LOCAL_DB_HOST=host.docker.internal
LOCAL_DB_PORT=3306
LOCAL_DB_NAME=yunyu
LOCAL_DB_USER=root
LOCAL_DB_PASSWORD=123456

# 远程数据库配置
REMOTE_DB_HOST=127.0.0.1
REMOTE_DB_PORT=3306
REMOTE_DB_NAME=yunyu
REMOTE_DB_USER=root
REMOTE_DB_PASSWORD=123456
