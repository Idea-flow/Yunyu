# 功能：schema-diff 独立配置模板。
# 作用：为 scripts/release/schema-diff.sh 提供独立数据库连接配置，避免复用其他脚本环境变量文件。

# 远端数据库连接信息
REMOTE_DB_HOST=host.docker.internal
REMOTE_DB_PORT=3306
REMOTE_DB_NAME=yunyu
REMOTE_DB_USER=yunyu
REMOTE_DB_PASSWORD=yunyu123456

# 可选：MySQL 客户端镜像
MYSQL_CLIENT_IMAGE=mysql:8.4

# 可选：已启动的 MySQL 客户端容器名（配置后优先使用 docker exec）
# 示例：MYSQL_CLIENT_CONTAINER=yunyu-mysql
# MYSQL_CLIENT_CONTAINER=

# 可选：exec 模式下使用的数据库主机。
# 当 MYSQL_CLIENT_CONTAINER 指向数据库容器本身时，建议设置为 127.0.0.1。
# MYSQL_EXEC_DB_HOST=127.0.0.1
